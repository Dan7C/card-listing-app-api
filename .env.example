# API Keys
GROQ_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# LLM retry settings - fixed interval for timeouts and unexpected errors
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_INTERVAL_SECONDS=10

# Database retry settings - fixed interval for Supabase cold start
DB_RETRY_ATTEMPTS=6
DB_RETRY_INTERVAL_SECONDS=10

# Fuzzy matching
FUZZY_MATCH_CUTOFF=0.8

# Application settings
LOG_LEVEL=INFO
OUTPUTS_DIR=outputs